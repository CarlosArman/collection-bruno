meta {
  name: Create token
  type: http
  seq: 6
}

post {
  url: https://simple-books-api.glitch.me/api-clients/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
      "clientName": "test26",
      "clientEmail": "{{$randomEmail}}"
  }
}

script:post-response {
  const data = res.body;
  bru.setVar("simpleBooksToken", data.accessToken);
}
